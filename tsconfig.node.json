{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "typeRoots": ["./node_modules/@types"],
    "strict": true,
    "noEmit": true
  },
  "include": ["vite.config.ts"]
}
